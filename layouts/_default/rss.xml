{{- printf "<?xml version=&quot;1.0&quot; encoding=&quot;utf-8&quot; standalone=&quot;yes&quot;?>" | safeHTML -}}
<rss version="2.0" xmlns:content="" xmlns:atom="">
<channel>
<title>{{ if eq .Title .Site.Title }}{{ .Site.Title }}{{ else }}{{ with .Title }}{{.}} on {{ end }}{{ .Site.Title }}{{ end }}</title>
<link>{{ .Permalink }}</link>
<description>Recent content on {{ .Site.Title }}</description>
<generator>Hugo -- gohugo.io</generator>
{{ with .Site.LanguageCode }}<language>{{.}}</language>{{end}}
{{- with .OutputFormats.Get "RSS" -}}
{{ printf "<atom:link href=%q rel="self" type=%q />" .Permalink .MediaType | safeHTML }}
{{- end -}}
{{ range .Pages }}
<item>
<title>{{ .Title }}</title>
<link>{{ .Permalink }}</link>
<pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
<guid>{{ .Permalink }}</guid>
{{- $itemImage := "" -}}
{{- if .Params.image -}}
{{- $resource := .Resources.GetMatch .Params.image -}}
{{- if $resource -}}
{{- $itemImage = $resource.Permalink -}}
{{- else -}}
{{- $itemImage = .Params.image | absURL -}}
{{- end -}}
{{- end -}}
<description>
{{- if $itemImage -}}
{{- printf "<img src="%s" alt="%s" />" $itemImage .Title | html -}}
{{- end -}}
{{ .Summary | html }}
</description>

{{- if $itemImage -}}
{{- printf "<img src="%s" alt="%s" />" $itemImage .Title | html -}}
{{- end -}}
{{ .Content | html }}
</https://www.google.com/search?q=content:encoded>
</item>
{{ end }}
</channel>
</rss>